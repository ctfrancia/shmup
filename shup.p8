pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	score=0 -- max 32767
    mode="game" // "menu", "game", "credits"
    blinkt=0


    lives=2
    health=3
    healthspr=5
    healthmissingspr=6

    background={}
    background.max_height=128
    background.max_width=128
    background.stars={}
    for i=1,60 do -- set star pos
        add(background.stars,{
            x=flr(rnd(128)),
            y=flr(rnd(128)),
            s=rnd(3)
        })
    end
	
	ship={}
	ship.spr=2
	ship.flamespr=17
	ship.x=64
	ship.y=64
	ship.speedx=1
	ship.speedy=1
	
	bullets={}
	bulletspr=16
end

function _update()
    blinkt+=1
    if mode=="game" then
        update_game()
    elseif mode=="menu" then
        show_menu()
    end
end

function _draw()
    if mode=="game" then
        draw_game()
    elseif mode=="menu" then
        show_menu()
    end
end

-->8
function starfield()
    for i=1,#background.stars do
        if background.stars[i].s<=1.5 then
            pset(background.stars[i].x,background.stars[i].y,5)
        else
            pset(background.stars[i].x,background.stars[i].y,6)
        end
    end 
end

function animatestars()
    for i=1,#background.stars do
        background.stars[i].y+=background.stars[i].s
        if background.stars[i].y>background.max_height then
            background.stars[i].y=0
        end
    end 
end

function blink()
    return 7
end
-->8
function update_game()
    if lives == 0 then
        mode="menu"
    end
	ship.spr=2

	--animate flame
	ship.flamespr+=1
	if ship.flamespr > 19 then
		ship.flamespr=17
	end
	
	if btn(0) then--left
		ship.spr=1
		ship.x-=1
	end
	if btn(1) then--right
		ship.spr=3
		ship.x+=1
	end
	
	if btn(2) then--up
		ship.y-=1
	end
	
	if btn(3) then--down
		ship.y+=1
	end
	
	if btnp(5) then -- x
        add(bullets,{
            x=ship.x,
            y=ship.y-5,
            active=true,
            muzzle=5,
            muzzleact=true,
            speed=5
        })
		sfx(0)
	end
	
    for i=1,#bullets do
        bullets[i].y-=bullets[i].speed
        if bullets[i].y<0 then
            bullets[i].active=false
            del(bullets,i)
        end
    end


    --muzzle flash
    for i=1,#bullets do
        if bullets[i].muzzle>0 then
            bullets[i].muzzle-=1
        end
    end

	-- edge checker todo:sep func	
	if ship.x >= 120 then
			ship.x=120
	end
	
	if ship.x <= 0 then
		ship.x=0
	end
	
	if ship.y <= 0 then
		ship.y=0
	end
	
	if ship.y>=120 then
		ship.y=120
	end
end

function draw_game()
	cls()
    starfield()
	print("score:"..score,40,1,12)
	spr(ship.spr,ship.x,ship.y)
	spr(ship.flamespr,ship.x,ship.y+8)

    for i=1,#bullets do
        --bullets[i].y-=bullets[i].speed
        --bullets[i].muzzle-=1
    end

    for i=#bullets,1,-1 do  -- iterate backwards so del() doesn't skip entries
        local b=bullets[i]
        if b.active then

            --bullets[i].muzzle-=1

            spr(bulletspr,b.x,b.y)
            if b.muzzle > 0 then
                --circfill(b.x+3,b.y-2,b.muzzle,7)
                --circfill(b.x+3, b.y-2, 4, 8)
                circfill(ship.x+3, ship.y-5, b.muzzle, 7)
                 print(b.muzzle,0,0,7)
            end
        end
    end

    for i=1,health do -- draw health do this better
     if lives>=i then 
        spr(healthspr,i*9,0)
     else
        spr(healthmissingspr,i*9,0)
     end
    end
    animatestars()
end

function show_menu()
    cls(2)
    print("press 'x' to start game",20,64,blink())
    if btn(5) then
        mode="game"
        score=0
    end
end

